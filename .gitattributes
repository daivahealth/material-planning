# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always be normalized and converted
*.js text
*.ts text
*.tsx text
*.css text
*.html text
*.md text
*.py text
*.sh text
*.yml text
*.yaml text
*.json text
*.csv text

# Denote files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
